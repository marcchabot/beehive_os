{
  "schema_version": "1.2",
  "version": "1.3.6",
  "theme": "HoneyDark",
  "lang": "en",
  "_comment": "Bee-Hive OS — Community configuration file. Modify the values below to customize your hive.",
  "transitions": {
    "theme_duration_ms": 600
  },
  "weather": {
    "city": "Montreal",
    "unit": "metric",
    "lang": "en"
  },
  "dashboard": {
    "title": "🍯 My Hive",
    "cells": [
      {
        "icon": "📅",
        "title": "Calendar",
        "subtitle": "My Events",
        "detail": "No events\nat the moment",
        "action": "url:https://calendar.google.com",
        "highlighted": true,
        "customizable": true,
        "color": ""
      },
      {
        "icon": "🖥️",
        "title": "System",
        "subtitle": "CachyOS",
        "detail": "Hyprland\nQuickshell",
        "action": "app:kitty",
        "highlighted": true,
        "customizable": true,
        "color": ""
      },
      {
        "icon": "⚙️",
        "title": "Settings",
        "subtitle": "Bee-Hive OS",
        "detail": "Configuration\n& Preferences",
        "action": "toggle:settings",
        "highlighted": true,
        "customizable": false,
        "color": ""
      }
    ]
  },
  "nectar_sync": true,
  "stealth_mode": false,
  "beebar_stats": {
    "cpu": true,
    "ram": true,
    "net": true,
    "disk": true,
    "battery": true
  },
  "bee_events": {
    "enabled": true,
    "max_events": 3
  },
  "framework": {
    "name": "Bee-Hive OS",
    "version": "1.3.6",
    "author": "Bee-Hive Community",
    "license": "MIT"
  },
  "vibe_mode": false,
  "corners_mode": true,
  "motion_mode": true,
  "pinned_apps": [
    "__settings__",
    "__studio__",
    "kitty"
  ],
  "analog_clock": true,
  "focus_mode": false
}
