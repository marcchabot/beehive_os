  "calendars": [
    {
      "id": "famille",
      "type": "ics",
      "url": "",
      "label": "Famille",
      "color": "#FFB81C"
    },
    {
      "id": "pharmacie",
      "type": "ics",
      "url": "",
      "label": "Pharmacie",
      "color": "#4CAF50"
    }
  ],
  "live_sync": {
    "enabled": true,
    "interval_seconds": 900,
    "max_events": 5,
    "lookahead_days": 14
  },
  "events_ics_url": "",
  "_comment_migration": "If you have an existing events_ics_url, run scripts/bee_migrate_sync_v2.sh to migrate automatically to the calendars array.",
  "framework": {
    "name": "Bee-Hive OS",
    "version": "1.7.0",
    "author": "Bee-Hive Community",
    "license": "MIT"
  },
  "vibe_mode": false,
  "corners_mode": true,
  "motion_mode": true,
  "pinned_apps": [
    "__settings__",
    "__studio__",
    "kitty"
