    "theme_duration_ms": 600
  },
  "weather": {
    "city": "Montreal",
    "unit": "metric",
    "lang": "en"
  },
  "dashboard": {
    "title": "🍯 My Hive",
    "cells": [
      {
        "icon": "📅",
        "title": "Calendar",
        "subtitle": "My Events",
        "detail": "No events\nat the moment",
        "action": "url:https://calendar.google.com",
        "highlighted": true,
        "customizable": true,
        "color": ""
      },
      {
        "icon": "🖥️",
        "title": "System",
        "subtitle": "CachyOS",
        "detail": "Hyprland\nQuickshell",
        "action": "app:kitty",
        "highlighted": true,
        "customizable": true,
        "color": ""
      },
      {
        "icon": "⚙️",
        "title": "Settings",
        "subtitle": "Bee-Hive OS",
        "detail": "Configuration\n& Preferences",
        "action": "toggle:settings",
        "highlighted": true,
        "customizable": false,
        "color": ""
      }
    ]
  },
  "nectar_sync": true,
  "stealth_mode": false,
  "beebar_stats": {
    "cpu": true,
    "ram": true,
    "net": true,
    "disk": true,
    "battery": true
  },
  "events_enabled": true,
  "bee_events": {
    "enabled": true,
    "max_events": 3
  },
