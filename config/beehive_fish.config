# ═══════════════════════════════════════════════════════════════
# Bee-Hive OS — Fish Configuration v1.1.2 🐝🍯
# ═══════════════════════════════════════════════════════════════

# --- 🍯 Affichage de bienvenue (MOTD) ---
if status is-interactive
    fastfetch
end

# --- 🎨 Couleurs Bee-Hive (GLOBALES pour forcer la visibilité) ---
set -g fish_color_normal FFFFFF
set -g fish_color_command FFB81C --bold
set -g fish_color_param FFFFFF
set -g fish_color_keyword FFB81C
set -g fish_color_quote 50FA7B
set -g fish_color_redirection 8BE9FD
set -g fish_color_end FFB81C
set -g fish_color_error FF5555
set -g fish_color_comment CCCCCC
set -g fish_color_autosuggestion CCCCCC
set -g fish_color_selection --background=444444
set -g fish_color_search_match --background=444444
set -g fish_color_operator 8BE9FD
set -g fish_color_escape 8BE9FD
set -g fish_color_cancel FF5555

# --- 🐝 Fix Spécifique Git Prompt (main*) ---
set -g __fish_git_prompt_color_branch FFFFFF --bold
set -g __fish_git_prompt_color_dirtystate FFB81C --bold
set -g __fish_git_prompt_color_stagedstate 50FA7B --bold
set -g __fish_git_prompt_color_invalidstate FF5555 --bold
set -g __fish_git_prompt_color_untrackedstate FFFFFF --bold
set -g __fish_git_prompt_color_cleanstate 50FA7B --bold

# --- 🐝 Abeille dans le Prompt principal ---
# On remplace l'icône actuelle par l'abeille emoji dorée !
function fish_prompt
    set_color white
    echo -n (prompt_pwd)
    set_color yellow
    echo -n " "(__fish_git_prompt)
    set_color normal
    echo -n " 🐝 "  # L'abeille qui marche à tous les coups !
end

# --- 🚀 Aliases Bee-Hive ---
alias ls='ls -lh --color=auto'  # 🍯 Par défaut : liste verticale et détaillée
alias ll='ls -lh --color=auto'
alias la='ls -Alh --color=auto'
alias l='ls -CF --color=auto'
alias gs='git status'
alias gp='git pull'
alias gpp='git push'
alias ff='fastfetch'
alias bee='cd ~/beehive_os'
alias maya='openclaw status'

# --- 🛡️ Environnement ---
set -gx EDITOR nvim
set -gx VISUAL nvim
set -g fish_greeting ""
